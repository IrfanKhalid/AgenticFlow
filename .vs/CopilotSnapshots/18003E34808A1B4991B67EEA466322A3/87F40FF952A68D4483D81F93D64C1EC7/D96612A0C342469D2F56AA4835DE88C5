using System;
using System.Collections.Generic;
using System.Net.Http;
using System.Threading.Tasks;
using System.Threading;
using Cronos;
using HtmlAgilityPack;

class Program
{
    // Example: run every minute
    private const string CronExpression = "*/1 * * * *";

    static async Task<int> Main(string[] args)
    {
        Console.WriteLine("Cron Scheduler starting...");

        var cron = CronExpression.Parse(CronExpression, CronFormat.Standard);
        var cts = new CancellationTokenSource();

        Console.CancelKeyPress += (s, e) =>
        {
            Console.WriteLine("Shutting down...");
            e.Cancel = true;
            cts.Cancel();
        };

        var scheduler = new Scheduler(cron, cts.Token);

        // Add sites to crawl here or read from args/config
        var sites = new List<string>
        {
            "https://example.com",
        };

        await foreach (var _ in scheduler.RunAsync())
        {
            Console.WriteLine($"Trigger fired at {DateTimeOffset.Now}");
            foreach (var site in sites)
            {
                try
                {
                    var titles = await CrawlSiteAsync(site, cts.Token);
                    Console.WriteLine($"Site: {site} Titles:\n{string.Join('\n', titles)}\n");
                }
                catch (OperationCanceledException) when (cts.IsCancellationRequested)
                {
                    // shutdown
                    break;
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error crawling {site}: {ex.Message}");
                }
            }

            if (cts.IsCancellationRequested)
                break;
        }

        Console.WriteLine("Scheduler stopped.");
        return 0;
    }

    static async Task<IEnumerable<string>> CrawlSiteAsync(string url, CancellationToken cancellationToken)
    {
        using var http = new HttpClient();
        http.Timeout = TimeSpan.FromSeconds(30);
        var html = await http.GetStringAsync(url, cancellationToken);

        var doc = new HtmlDocument();
        doc.LoadHtml(html);
        var titles = new List<string>();
        // extract <h1> and <title>
        var titleNode = doc.DocumentNode.SelectSingleNode("//title");
        if (titleNode != null) titles.Add(titleNode.InnerText.Trim());

        var h1 = doc.DocumentNode.SelectSingleNode("//h1");
        if (h1 != null) titles.Add(h1.InnerText.Trim());

        return titles;
    }
}

class Scheduler
{
    private readonly CronExpression _cron;
    private readonly CancellationToken _cancellationToken;

    public Scheduler(CronExpression cron, CancellationToken cancellationToken)
    {
        _cron = cron;
        _cancellationToken = cancellationToken;
    }

    public async IAsyncEnumerable<DateTimeOffset> RunAsync()
    {
        while (!_cancellationToken.IsCancellationRequested)
        {
            var next = _cron.GetNextOccurrence(DateTimeOffset.UtcNow);
            if (!next.HasValue)
                yield break;

            var delay = next.Value - DateTimeOffset.UtcNow;
            if (delay.TotalMilliseconds > 0)
            {
                try
                {
                    await Task.Delay(delay, _cancellationToken);
                }
                catch (OperationCanceledException)
                {
                    yield break;
                }
            }

            yield return next.Value;
        }
    }
}
